<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    
    <!-- SEO Meta Tags -->
    <title>WanderIndia - Premium Travel Agency & Custom Expeditions</title>
    <meta name="description" content="WanderIndia is your premium travel partner for exploring Incredible India. Book custom expeditions, holiday packages to Ladakh, Rajasthan, Kerala, and Goa.">
    <meta name="keywords" content="India travel agency, Ladakh expedition, Rajasthan heritage tours, custom India trips, WanderIndia, top India destinations, holiday packages, Rann Utsav, Hornbill Festival">
    <meta name="author" content="WanderIndia Travels">
    <meta name="robots" content="index, follow">
    <link rel="canonical" href="https://www.wanderindia.com/">
    <link rel="sitemap" type="application/xml" title="Sitemap" href="/sitemap.xml">

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://www.wanderindia.com/">
    <meta property="og:title" content="WanderIndia - Premium Travel Agency">
    <meta property="og:description" content="Discover the Magic of Incredible India. Explore top-rated tour packages and custom trip planning.">
    <meta property="og:image" content="images/og-image.jpg">

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image">
    <meta property="twitter:url" content="https://www.wanderindia.com/">
    <meta property="twitter:title" content="WanderIndia - Premium Travel Agency">
    <meta property="twitter:description" content="Discover the Magic of Incredible India. Explore top-rated tour packages and custom trip planning.">
    <meta property="twitter:image" content="images/og-image.jpg">

    <!-- JSON-LD Schema Markup -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "TravelAgency",
      "name": "WanderIndia",
      "image": "images/og-image.jpg",
      "@id": "https://www.wanderindia.com",
      "url": "https://www.wanderindia.com",
      "telephone": "+919876543210",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "123 Travel Hub, MG Road",
        "addressLocality": "Bangalore",
        "postalCode": "560001",
        "addressCountry": "IN"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 12.9716,
        "longitude": 77.5946
      },
      "sameAs": [
        "https://www.facebook.com/wanderindia",
        "https://www.instagram.com/wanderindia",
        "https://twitter.com/wanderindia"
      ]
    }
    </script>
    
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    
    <!-- Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>

    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Playfair+Display:ital,wght@0,700;1,700&display=swap" rel="stylesheet">

    <!-- Custom CSS -->
    <style>
        body { font-family: 'Inter', sans-serif; scroll-behavior: smooth; }
        .font-serif { font-family: 'Playfair Display', serif; }
        
        /* SPA Navigation Animations */
        .page-section { display: none; opacity: 0; transition: opacity 0.4s ease-in-out; }
        .page-section.active { display: block; animation: fadeIn 0.5s forwards; }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(15px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* Abstract Visual Map Itinerary Styles */
        .map-silhouette {
            background-color: #f8fafc;
            border-radius: 43% 57% 65% 35% / 45% 42% 58% 55%;
            box-shadow: inset 0 0 50px rgba(0,0,0,0.05), 0 25px 50px -12px rgba(0, 0, 0, 0.1);
            position: relative;
        }

        .itinerary-line {
            position: absolute; top: 60px; bottom: 60px; left: 50%;
            width: 4px; border-left: 4px dashed #94a3b8; transform: translateX(-50%); z-index: 1;
        }

        .route-node { position: relative; width: 100%; display: flex; margin-bottom: 3rem; }
        .route-node:nth-child(odd) { justify-content: flex-start; }
        .route-node:nth-child(even) { justify-content: flex-end; }
        
        @media (min-width: 768px) {
            .route-node:nth-child(odd) > div:first-child { transform: translateX(-30px); text-align: right; }
            .route-node:nth-child(even) > div:first-child { transform: translateX(30px); text-align: left; }
            .route-node:nth-child(odd) .node-header { justify-content: flex-end; }
            .route-node:nth-child(even) .node-header { justify-content: flex-start; }
        }

        @media (max-width: 768px) {
            .map-silhouette { border-radius: 30px; padding-left: 1rem; padding-right: 1rem; }
            .itinerary-line { left: 32px; border-left-width: 3px; }
            .route-node { justify-content: flex-end !important; padding-left: 3rem; }
            .route-node:nth-child(odd) > div:first-child, .route-node:nth-child(even) > div:first-child { 
                transform: translateX(0); text-align: left; width: 100%; 
            }
            .route-node .node-header { justify-content: flex-start !important; }
            .pin-marker { left: 32px !important; transform: translate(-50%, -50%) !important; }
        }

        .line-clamp-2 { display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
        .line-clamp-3 { display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }

        #chat-messages::-webkit-scrollbar { width: 5px; }
        #chat-messages::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 5px; }

        .masonry-grid { columns: 1; column-gap: 2rem; }
        @media (min-width: 768px) { .masonry-grid { columns: 2; } }
        @media (min-width: 1024px) { .masonry-grid { columns: 3; } }
        .masonry-item { break-inside: avoid; margin-bottom: 2rem; display: inline-block; width: 100%; }

        .ticket-shape {
            mask-image: radial-gradient(circle at 0 50%, transparent 12px, black 13px), radial-gradient(circle at 100% 50%, transparent 12px, black 13px);
            mask-size: 51% 100%; mask-repeat: no-repeat; mask-position: left, right;
            -webkit-mask-image: radial-gradient(circle at 0 50%, transparent 12px, black 13px), radial-gradient(circle at 100% 50%, transparent 12px, black 13px);
            -webkit-mask-size: 51% 100%; -webkit-mask-repeat: no-repeat; -webkit-mask-position: left, right;
        }
    </style>
</head>
<body class="bg-gray-50 text-gray-900 flex flex-col min-h-screen overflow-x-hidden">

    <!-- GLOBAL HEADER -->
    <header class="sticky top-0 z-50 bg-white/95 backdrop-blur-md shadow-sm border-b border-gray-100">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between items-center h-20">
                <div class="flex items-center cursor-pointer group" onclick="navigateTo('home')">
                    <div class="bg-indigo-900 p-2 rounded-xl mr-3 group-hover:bg-indigo-800 transition-colors">
                        <i data-lucide="crown" class="h-6 w-6 text-yellow-400"></i>
                    </div>
                    <span class="font-bold text-2xl tracking-tight text-gray-900 font-serif">Wander<span class="text-indigo-600">India</span></span>
                </div>

                <nav class="hidden md:flex space-x-8">
                    <button onclick="navigateTo('home')" class="nav-link text-sm font-bold tracking-wide transition-colors hover:text-indigo-600 text-gray-600 uppercase" data-target="home">Home</button>
                    <button onclick="navigateTo('destinations')" class="nav-link text-sm font-bold tracking-wide transition-colors hover:text-indigo-600 text-gray-600 uppercase" data-target="destinations">Expeditions</button>
                    <button onclick="navigateTo('past-events')" class="nav-link text-sm font-bold tracking-wide transition-colors hover:text-indigo-600 text-gray-600 uppercase" data-target="past-events">Legacy</button>
                    <button onclick="navigateTo('blogs')" class="nav-link text-sm font-bold tracking-wide transition-colors hover:text-indigo-600 text-gray-600 uppercase" data-target="blogs">Blogs</button>
                    <button onclick="navigateTo('planner')" class="nav-link text-sm font-bold tracking-wide transition-colors hover:text-indigo-600 text-gray-600 uppercase" data-target="planner">Trip Planner</button>
                </nav>

                <div class="hidden md:flex">
                    <button onclick="openWhatsApp('Hi WanderIndia! I want to explore your premium tours.')" class="bg-[#25D366] text-white px-6 py-2.5 rounded-full font-bold hover:bg-[#128C7E] shadow-lg shadow-green-200 transition-all transform hover:-translate-y-0.5 flex items-center">
                        <svg class="w-5 h-5 mr-2 fill-current" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/></svg>
                        WhatsApp Us
                    </button>
                </div>

                <div class="md:hidden flex items-center">
                    <button id="mobile-menu-btn" onclick="toggleMobileMenu()" class="text-gray-900 hover:text-indigo-600 focus:outline-none p-2 bg-gray-100 rounded-lg">
                        <i data-lucide="menu" class="h-6 w-6" id="menu-icon"></i>
                    </button>
                </div>
            </div>
        </div>

        <div id="mobile-menu" class="hidden md:hidden bg-white border-t border-gray-100 absolute w-full shadow-2xl z-50 origin-top animate-fade-in">
            <div class="px-4 pt-4 pb-8 space-y-2">
                <button onclick="navigateTo('home'); toggleMobileMenu();" class="w-full text-left px-4 py-3 text-base font-bold text-gray-800 hover:text-indigo-600 hover:bg-indigo-50 rounded-xl transition-colors">Home</button>
                <button onclick="navigateTo('destinations'); toggleMobileMenu();" class="w-full text-left px-4 py-3 text-base font-bold text-gray-800 hover:text-indigo-600 hover:bg-indigo-50 rounded-xl transition-colors">Expeditions</button>
                <button onclick="navigateTo('past-events'); toggleMobileMenu();" class="w-full text-left px-4 py-3 text-base font-bold text-gray-800 hover:text-indigo-600 hover:bg-indigo-50 rounded-xl transition-colors">Legacy Events</button>
                <button onclick="navigateTo('blogs'); toggleMobileMenu();" class="w-full text-left px-4 py-3 text-base font-bold text-gray-800 hover:text-indigo-600 hover:bg-indigo-50 rounded-xl transition-colors">Travel Blogs</button>
                <button onclick="navigateTo('planner'); toggleMobileMenu();" class="w-full text-left px-4 py-3 text-base font-bold text-gray-800 hover:text-indigo-600 hover:bg-indigo-50 rounded-xl transition-colors">Trip Planner</button>
                <button onclick="openWhatsApp('Hi WanderIndia, I need assistance.'); toggleMobileMenu();" class="mt-4 w-full bg-[#25D366] text-white px-4 py-4 rounded-xl font-bold flex items-center justify-center">
                    <svg class="w-5 h-5 mr-2 fill-current" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/></svg>
                    Chat on WhatsApp
                </button>
            </div>
        </div>
    </header>

    <main class="flex-grow relative">
        
        <!-- PAGE 1: HOME -->
        <section id="page-home" class="page-section active">
            <div class="relative h-[85vh] md:h-[750px] flex items-center justify-center overflow-hidden">
                <div class="absolute inset-0">
                    <!-- Hero image: images/hero-india.jpg -->
                    <img src="images/hero-india.jpg" alt="India Landscape" class="w-full h-full object-cover transform scale-105 animate-[pulse_20s_ease-in-out_infinite_alternate]"/>
                    <div class="absolute inset-0 bg-gradient-to-b from-gray-900/60 via-gray-900/40 to-gray-900/80"></div>
                </div>
                
                <div class="relative z-10 text-center px-4 max-w-5xl mx-auto mt-10">
                    <div class="inline-flex items-center justify-center space-x-2 mb-6">
                        <div class="h-[1px] w-12 bg-yellow-400"></div>
                        <span class="text-yellow-400 font-bold tracking-[0.25em] uppercase text-xs sm:text-sm drop-shadow-md">The Crown of India Experiences</span>
                        <div class="h-[1px] w-12 bg-yellow-400"></div>
                    </div>
                    <h1 class="text-5xl md:text-7xl lg:text-8xl font-black text-white mb-6 drop-shadow-2xl leading-tight font-serif tracking-tight">
                        Travel India <br class="hidden md:block"/> in <span class="text-transparent bg-clip-text bg-gradient-to-r from-yellow-200 via-yellow-400 to-yellow-600">Every Season</span>
                    </h1>
                    <p class="text-lg md:text-2xl text-gray-200 mb-12 max-w-3xl mx-auto drop-shadow-lg font-light">
                        From the snow covered peak of Ladakh to the sun-soaked beaches of Goa and the lush monsoon trails of the Western Ghats, Experience India like never before. Curated trips, seamless planning, and unforgettable adventures, all year round.
                    </p>
                    
                    <div class="flex flex-col sm:flex-row justify-center items-center gap-5">
                        <button onclick="navigateTo('destinations')" class="w-full sm:w-auto bg-gradient-to-r from-yellow-400 to-yellow-500 hover:from-yellow-500 hover:to-yellow-600 text-blue-950 rounded-full px-10 py-4 font-black text-lg transition-all shadow-[0_10px_30px_rgba(234,179,8,0.4)] hover:-translate-y-1 flex items-center justify-center">
                            Explore Packages <i data-lucide="arrow-right" class="w-5 h-5 ml-2"></i>
                        </button>
                        <button onclick="navigateTo('planner')" class="w-full sm:w-auto bg-white/10 hover:bg-white/20 backdrop-blur-md text-white border border-white/40 rounded-full px-10 py-4 font-bold text-lg transition-all flex items-center justify-center hover:-translate-y-1">
                            <i data-lucide="calendar-plus" class="w-5 h-5 mr-2"></i> Plan Custom Trip
                        </button>
                    </div>
                </div>
            </div>

            <section class="py-24 bg-gray-50 relative">
                <div class="absolute top-0 left-0 w-full h-40 bg-gradient-to-b from-gray-900 to-transparent opacity-5"></div>
                <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
                    <div class="text-center mb-16">
                        <span class="text-indigo-600 font-bold tracking-widest uppercase text-sm mb-2 block">Festivals & Celebrations</span>
                        <h2 class="text-4xl md:text-5xl font-black text-gray-900 font-serif">Upcoming Holiday Events</h2>
                        <p class="text-gray-600 mt-4 max-w-2xl mx-auto text-lg">Immerse yourself in the vibrant colors, music, and profound traditions of India's most spectacular seasonal festivals.</p>
                    </div>
                    
                    <div id="home-events-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
                        <!-- Injected via JS -->
                    </div>
                </div>
            </section>

            <section class="py-24 bg-white border-t border-gray-100">
                <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                    <div class="text-center mb-16">
                        <span class="text-yellow-600 font-bold tracking-widest uppercase text-sm mb-2 block">Premium Curations</span>
                        <h2 class="text-4xl md:text-5xl font-black text-gray-900 mb-4 font-serif">Signature Expeditions</h2>
                        <p class="text-gray-600 max-w-2xl mx-auto text-lg">Handpicked itineraries designed to give you the most authentic, luxurious, and seamless experience.</p>
                    </div>

                    <div id="home-destinations-grid" class="grid grid-cols-1 lg:grid-cols-2 gap-10">
                        <!-- Injected via JS -->
                    </div>
                    
                    <div class="mt-16 text-center">
                        <button onclick="navigateTo('destinations')" class="inline-flex items-center text-xl font-bold text-indigo-700 hover:text-indigo-900 transition-colors group">
                            View All Expeditions 
                            <span class="bg-indigo-100 p-2 rounded-full ml-3 group-hover:bg-indigo-200 transition-colors"><i data-lucide="arrow-right" class="w-5 h-5"></i></span>
                        </button>
                    </div>
                </div>
            </section>
        </section>

        <!-- PAGE 2: DESTINATIONS LIST -->
        <section id="page-destinations" class="page-section bg-gray-50 min-h-screen py-20">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="mb-16 text-center">
                    <span class="text-indigo-600 font-bold tracking-widest uppercase text-sm mb-2 block">Choose Your Adventure</span>
                    <h1 class="text-5xl md:text-6xl font-black text-gray-900 mb-6 font-serif">All Expeditions</h1>
                    <p class="text-xl text-gray-600 max-w-3xl mx-auto">Select your next journey from our premium collection of Indian itineraries, tailored for perfection.</p>
                </div>
                <div id="all-destinations-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
                    <!-- Injected via JS -->
                </div>
            </div>
        </section>

        <!-- PAGE 3: PLAN/EXPEDITION DETAILS -->
        <section id="page-plan-details" class="page-section bg-gray-50 pb-24">
            <div id="plan-details-content">
                <!-- Injected via JS -->
            </div>
        </section>

        <!-- PAGE 4: EVENT DETAILS -->
        <section id="page-event-details" class="page-section bg-gray-50 pb-24">
            <div id="event-details-content">
                <!-- Injected via JS -->
            </div>
        </section>

        <!-- PAGE 5: PAST EVENTS -->
        <section id="page-past-events" class="page-section bg-white min-h-screen py-20">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="text-center mb-20">
                    <span class="text-indigo-600 font-bold tracking-widest uppercase text-sm mb-2 block">Our Legacy</span>
                    <h1 class="text-5xl md:text-6xl font-black text-gray-900 mb-6 font-serif">Past Expeditions</h1>
                    <p class="text-xl text-gray-600 max-w-3xl mx-auto">Relive the magic of our most successful and thrilling group journeys. Read what our travelers had to say.</p>
                </div>
                <div id="past-events-grid" class="grid grid-cols-1 md:grid-cols-2 gap-12">
                    <!-- Injected via JS -->
                </div>
            </div>
        </section>

        <!-- PAGE 6: BLOGS HUB -->
        <section id="page-blogs" class="page-section bg-gray-50 min-h-screen py-20">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="text-center mb-16">
                    <span class="text-indigo-600 font-bold tracking-widest uppercase text-sm mb-2 block">WanderIndia Journals</span>
                    <h1 class="text-5xl md:text-6xl font-black text-gray-900 mb-6 font-serif">Travel Diaries</h1>
                    <p class="text-xl text-gray-600 max-w-3xl mx-auto">Inspiration, essential tips, and incredible stories from the road. Discover the hidden gems of India through our experts.</p>
                </div>
                <div id="blogs-grid" class="masonry-grid">
                    <!-- Injected via JS -->
                </div>
            </div>
        </section>

        <!-- PAGE 7: BLOG DETAILS -->
        <section id="page-blog-details" class="page-section bg-white pb-24">
            <div id="blog-details-content">
                <!-- Injected via JS -->
            </div>
        </section>

        <!-- PAGE 8: TRIP PLANNER -->
        <section id="page-planner" class="page-section min-h-screen bg-indigo-900 py-20 px-4 sm:px-6">
            <!-- (Same as original, unchanged) -->
        </section>

    </main>

    <!-- FOOTER -->
    <footer class="bg-gray-900 text-white pt-20 pb-10 border-t-8 border-indigo-900">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 mb-16">
                <div class="col-span-1 md:col-span-1">
                    <div class="flex items-center mb-6">
                        <i data-lucide="crown" class="h-8 w-8 text-yellow-400 mr-2"></i>
                        <span class="font-bold text-3xl tracking-tight font-serif">Wander<span class="text-yellow-400">India</span></span>
                    </div>
                    <p class="text-gray-400 text-sm leading-relaxed mb-8">
                        Crafting unforgettable, premium Indian experiences. From the peaks of the Himalayas to the backwaters of Kerala, your royal journey begins here.
                    </p>
                    <div class="flex space-x-4">
                        <a href="#" class="bg-gray-800 p-3 rounded-xl text-gray-400 hover:text-white hover:bg-indigo-600 transition-all hover:-translate-y-1"><i data-lucide="instagram" class="w-5 h-5"></i></a>
                        <a href="#" class="bg-gray-800 p-3 rounded-xl text-gray-400 hover:text-white hover:bg-indigo-600 transition-all hover:-translate-y-1"><i data-lucide="facebook" class="w-5 h-5"></i></a>
                        <a href="#" class="bg-gray-800 p-3 rounded-xl text-gray-400 hover:text-white hover:bg-indigo-600 transition-all hover:-translate-y-1"><i data-lucide="twitter" class="w-5 h-5"></i></a>
                    </div>
